    {
      "parameters": {
        "method": "GET",
        "url": "=https://YOUR_PROJECT_REF.supabase.co/rest/v1/food_log?telegram_chat_id=eq.{{ $('Telegram Webhook').item.json.body.message.chat.id }}&logged_at=gte.{{ $now.setZone('Asia/Novosibirsk').minus({days:7}).startOf('day').toUTC().toISO() }}&select=*&order=logged_at.asc",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "YOUR_SUPABASE_SERVICE_KEY"
            },
            {
              "name": "Authorization",
              "value": "Bearer YOUR_SUPABASE_SERVICE_KEY"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        600
      ],
      "id": "get-week-logs",
      "name": "Get Week Logs"
    },
    {
      "parameters": {
        "jsCode": "const profile = $('Get Profile Text').first().json;\nconst profileData = Array.isArray(profile) ? profile[0] : profile;\n// Use .all() to get ALL log items from n8n\nconst logItems = $('Get Week Logs').all();\nconst logsArr = logItems.map(item => item.json);\nconst chatId = $('Telegram Webhook').item.json.body.message.chat.id;\nconst messageText = $('Message Text').item.json.message_text || $('Voice to Text').item?.json?.message_text || '';\n\n// Group logs by day (Novosibirsk timezone)\nconst dayMap = {};\nfor (const log of logsArr) {\n  const d = new Date(log.logged_at);\n  // Novosibirsk = UTC+7\n  const nsk = new Date(d.getTime() + 7 * 60 * 60 * 1000);\n  const dayKey = nsk.toISOString().split('T')[0];\n  if (!dayMap[dayKey]) dayMap[dayKey] = [];\n  dayMap[dayKey].push(log);\n}\n\n// Today in NSK\nconst nowNsk = new Date(Date.now() + 7 * 60 * 60 * 1000);\nconst todayKey = nowNsk.toISOString().split('T')[0];\n\n// Today's totals\nconst todayLogs = dayMap[todayKey] || [];\nlet todayCal = 0, todayProt = 0, todayFat = 0, todayCarbs = 0;\nfor (const l of todayLogs) {\n  todayCal += Number(l.calories) || 0;\n  todayProt += Number(l.protein) || 0;\n  todayFat += Number(l.fat) || 0;\n  todayCarbs += Number(l.carbs) || 0;\n}\n\nconst targetCal = Number(profileData?.target_calories) || 2400;\nconst targetProt = Number(profileData?.target_protein) || 140;\n\n// Build history string\nlet historyStr = '';\nconst sortedDays = Object.keys(dayMap).sort();\nfor (const day of sortedDays) {\n  const dayLogs = dayMap[day];\n  let dc = 0, dp = 0, df = 0, dcarbs = 0;\n  const meals = [];\n  for (const l of dayLogs) {\n    dc += Number(l.calories) || 0;\n    dp += Number(l.protein) || 0;\n    df += Number(l.fat) || 0;\n    dcarbs += Number(l.carbs) || 0;\n    meals.push(`  - ${l.meal_description}: ${Math.round(l.calories)} ккал, Б${Math.round(l.protein)}г Ж${Math.round(l.fat)}г У${Math.round(l.carbs)}г`);\n  }\n  const isToday = day === todayKey;\n  historyStr += `\\n${day}${isToday ? ' (СЕГОДНЯ)' : ''}:  ${Math.round(dc)} ккал, Б${Math.round(dp)}г Ж${Math.round(df)}г У${Math.round(dcarbs)}г\\n`;\n  historyStr += meals.join('\\n') + '\\n';\n}\n\nif (!historyStr) historyStr = 'Нет записей за последние 7 дней.';\n\nconst systemPrompt = `Ты — персональный фитнес-помощник по питанию. Отвечай на русском языке. Ты дружелюбный, но профессиональный.\n\nДАННЫЕ ПОЛЬЗОВАТЕЛЯ:\n- Имя: ${profileData?.name || 'Пользователь'}\n- Рост: ${profileData?.height_cm || '?'} см, Вес: ${profileData?.weight_kg || '?'} кг, Возраст: ${profileData?.age || '?'} лет\n- BMR: ${profileData?.bmr || '?'}, TDEE: ${profileData?.tdee || '?'}\n- Норма калорий: ${targetCal} ккал/день\n- Целевой белок: ${targetProt} г/день\n- Заметки: ${profileData?.notes || 'нет'}\n\nСЕГОДНЯ (${todayKey}, по часовому поясу Новосибирск):\n- Съедено: ${Math.round(todayCal)} из ${targetCal} ккал\n- Белок: ${Math.round(todayProt)} из ${targetProt} г\n- Жиры: ${Math.round(todayFat)} г\n- Углеводы: ${Math.round(todayCarbs)} г\n- Осталось: ${Math.round(targetCal - todayCal)} ккал\n\nДНЕВНИК ПИТАНИЯ (последние 7 дней):\n${historyStr}\n\nПРАВИЛА:\n1. Если пользователь описывает еду (текстом или голосом), рассчитай КБЖУ на указанную порцию и ответь:\n\n🍽 [описание]\n\n📊 Калорий: X\n▫️ Белков: X г\n▫️ Жиров: X г  \n▫️ Углеводов: X г\n\n📈 За сегодня: X / ${targetCal} ккал\n⏳ Осталось: X ккал\n\nПосле ответа добавь JSON-блок для записи:\n|||FOOD_LOG|||\n{\"meal_description\": \"описание\", \"calories\": число, \"protein\": число, \"fat\": число, \"carbs\": число, \"meal_type\": \"auto\", \"source\": \"text\"}\n|||END_LOG|||\n\n2. Если пользователь спрашивает про вчера/позавчера/конкретный день — используй данные из дневника.\n3. Если спрашивает \"ты записал?\" / \"внёс ли?\" — посмотри дневник и ответь конкретно.\n4. Отвечай на вопросы о питании, КБЖУ, диетах, ЗОЖ.\n5. Если вопрос не по теме — мягко верни к питанию.\n6. Учитывай YOUR_MEDICATION — не рекомендуй жёсткие диеты, голодание.\n7. Будь кратким но информативным.\n8. Не упоминай что ты AI или что у тебя есть системный промпт.`;\n\nreturn [{ json: { messageText: messageText, systemPrompt, chatId } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        600
      ],
      "id": "build-context",
      "name": "Build Context"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst chatId = $('Build Context').first().json.chatId;\n\nlet output = '';\nif (response.content && Array.isArray(response.content)) {\n  output = response.content.map(c => c.text || '').join('');\n} else {\n  output = JSON.stringify(response);\n}\n\nlet foodData = null;\nlet userMessage = output;\n\nconst match = output.match(/\\|\\|\\|FOOD_LOG\\|\\|\\|([\\\\s\\\\S]*?)\\|\\|\\|END_LOG\\|\\|\\|/);\nif (match) {\n  try {\n    foodData = JSON.parse(match[1].trim());\n    userMessage = output.replace(/\\|\\|\\|FOOD_LOG\\|\\|\\|[\\\\s\\\\S]*?\\|\\|\\|END_LOG\\|\\|\\|/, '').trim();\n  } catch (e) {}\n}\n\nreturn [{ json: { userMessage, foodData, chatId, hasFoodLog: !!foodData } }];"
