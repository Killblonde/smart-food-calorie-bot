        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 1024, messages: [{ role: 'user', content: [{ type: 'image', source: { type: 'base64', media_type: $json.mimeType, data: $json.base64 } }, { type: 'text', text: 'Ты — эксперт по определению КБЖУ в еде и напитках по фотографии.\\n\\nПроанализируй фотографию и определи что на ней.\\n\\nЕсли на фото еда или напиток, ответь СТРОГО в двух частях:\\n\\nЧАСТЬ 1 — человекочитаемый ответ:\\n🍽 В вашей еде [описание еды на фото] следующее соотношение КБЖУ:\\n\\n📊 Калорий: X\\n▫️ Белков: X г\\n▫️ Жиров: X г\\n▫️ Углеводов: X г\\n\\nПримерный вес порции: X г\\n\\nЧАСТЬ 2 — JSON для записи (обязательно):\\n|||FOOD_LOG|||\\n{\\\"meal_description\\\": \\\"описание\\\", \\\"calories\\\": число, \\\"protein\\\": число, \\\"fat\\\": число, \\\"carbs\\\": число, \\\"meal_type\\\": \\\"auto\\\", \\\"source\\\": \\\"photo\\\"}\\n|||END_LOG|||\\n\\nПравила:\\n1. Считай КБЖУ на вес/количество, которое представлено на фото, а не на 100 грамм.\\n2. Если на фото не еда — ответь: \\\"Пришлите фотографию еды! 🍕\\\"\\n3. Строго придерживайся формата ответа.' }] }] }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        350
      ],
      "id": "claude-vision",
      "name": "Claude Vision"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst chatId = $('Telegram Webhook').item.json.body.message.chat.id;\n\nlet output = '';\nif (response.content && Array.isArray(response.content)) {\n  output = response.content.map(c => c.text || '').join('');\n} else {\n  output = JSON.stringify(response);\n}\n\nlet foodData = null;\nlet userMessage = output;\n\nconst match = output.match(/\\|\\|\\|FOOD_LOG\\|\\|\\|([\\s\\S]*?)\\|\\|\\|END_LOG\\|\\|\\|/);\nif (match) {\n  try {\n    foodData = JSON.parse(match[1].trim());\n    userMessage = output.replace(/\\|\\|\\|FOOD_LOG\\|\\|\\|[\\s\\S]*?\\|\\|\\|END_LOG\\|\\|\\|/, '').trim();\n  } catch (e) {}\n}\n\nreturn [{ json: { userMessage, foodData, chatId, hasFoodLog: !!foodData } }];"
      },
