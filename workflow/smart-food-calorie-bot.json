        "url": "=https://YOUR_PROJECT_REF.supabase.co/rest/v1/food_log?telegram_chat_id=eq.{{ $('Telegram Webhook').item.json.body.message.chat.id }}&logged_at=gte.{{ $now.setZone('Asia/Novosibirsk').startOf('day').toUTC().toISO() }}&logged_at=lt.{{ $now.setZone('Asia/Novosibirsk').plus({days:1}).startOf('day').toUTC().toISO() }}&select=*",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "YOUR_SUPABASE_SERVICE_KEY"
            },
