      "id": "get-today-logs-stats",
      "name": "Get Today Logs Stats"
    },
    {
      "parameters": {
        "jsCode": "const profileItem = $('Get Profile Stats').first().json;\nconst profile = Array.isArray(profileItem) ? profileItem[0] : profileItem;\n\nconst logItems = $('Get Today Logs Stats').all();\n\nlet totalCal = 0, totalProt = 0, totalFat = 0, totalCarbs = 0;\nconst meals = [];\n\nfor (const item of logItems) {\n  const log = item.json;\n  totalCal += Number(log.calories) || 0;\n  totalProt += Number(log.protein) || 0;\n  totalFat += Number(log.fat) || 0;\n  totalCarbs += Number(log.carbs) || 0;\n  meals.push(`\\u2022 ${log.meal_description}: ${Math.round(log.calories)} \\u043a\\u043a\\u0430\\u043b`);\n}\n\nconst targetCal = Number(profile.target_calories) || 2400;\nconst targetProt = Number(profile.target_protein) || 140;\nconst remaining = Math.round(targetCal - totalCal);\nconst protRemaining = Math.round(targetProt - totalProt);\n\nlet status = '';\nif (remaining > 500) status = '\\u2705 \\u041e\\u0442\\u043b\\u0438\\u0447\\u043d\\u043e, \\u0437\\u0430\\u043f\\u0430\\u0441 \\u0435\\u0441\\u0442\\u044c!';\nelse if (remaining > 0) status = '\\u26a1 \\u041f\\u043e\\u0447\\u0442\\u0438 \\u0443 \\u0446\\u0435\\u043b\\u0438';\nelse status = '\\ud83d\\udd34 \\u041b\\u0438\\u043c\\u0438\\u0442 \\u043f\\u0440\\u0435\\u0432\\u044b\\u0448\\u0435\\u043d!';\n\nconst mealsList = meals.length > 0 ? '\\ud83c\\udf7d \\u041f\\u0440\\u0438\\u0451\\u043c\\u044b \\u043f\\u0438\\u0449\\u0438:\\\\n' + meals.join('\\\\n') : '\\u041f\\u043e\\u043a\\u0430 \\u043d\\u0438\\u0447\\u0435\\u0433\\u043e \\u043d\\u0435 \\u0437\\u0430\\u043f\\u0438\\u0441\\u0430\\u043d\\u043e.';\n\nconst message = `\\ud83d\\udcca \\u0421\\u0442\\u0430\\u0442\\u0438\\u0441\\u0442\\u0438\\u043a\\u0430 \\u0437\\u0430 \\u0441\\u0435\\u0433\\u043e\\u0434\\u043d\\u044f:\\n\\n\\ud83d\\udd25 \\u041a\\u0430\\u043b\\u043e\\u0440\\u0438\\u0438: ${Math.round(totalCal)} / ${targetCal} \\u043a\\u043a\\u0430\\u043b\\n\\ud83e\\udd69 \\u0411\\u0435\\u043b\\u043e\\u043a: ${Math.round(totalProt)} / ${targetProt} \\u0433\\n\\ud83e\\uddc8 \\u0416\\u0438\\u0440\\u044b: ${Math.round(totalFat)} \\u0433\\n\\ud83c\\udf5e \\u0423\\u0433\\u043b\\u0435\\u0432\\u043e\\u0434\\u044b: ${Math.round(totalCarbs)} \\u0433\\n\\n\\u23f3 \\u041e\\u0441\\u0442\\u0430\\u043b\\u043e\\u0441\\u044c: ${remaining} \\u043a\\u043a\\u0430\\u043b | ${protRemaining} \\u0433 \\u0431\\u0435\\u043b\\u043a\\u0430\\n\\n${status}\\n\\n${mealsList}`;\n\nreturn [{ json: { message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        100
